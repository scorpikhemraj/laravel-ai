{
    "name": "khemraj/laravel-dashboard",
    "description": "A fully dynamic, modular dashboard builder for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Khemraj",
            "email": "khemraj@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Khemraj\\LaravelDashboard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Khemraj\\LaravelDashboard\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Khemraj\\LaravelDashboard\\DashboardServiceProvider"
            ],
            "aliases": {
                "Dashboard": "Khemraj\\LaravelDashboard\\Facades\\Dashboard"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
